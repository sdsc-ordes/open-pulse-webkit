{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--headless",
        "--allowed-origins",
        "http://localhost:5173;http://localhost:4173;http://127.0.0.1:5173;http://127.0.0.1:4173"
      ]
    }
  }
}
