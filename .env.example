# ── Open Pulse — hub gateway ──────────────────────────────────────────────
# Copy to `.env` and fill in. Server-side only — these values must NOT be
# exposed to the browser. A server-side route (serverless function, small
# API, or your framework's server route) is expected to proxy client queries
# through, so credentials never leave the host.
#
# Everything goes through ONE HTTPS gateway. The raw store ports
# (Neo4j :7503/:7504, Oxigraph :7502, OpenSearch :7508/:9200) are plain
# HTTP / self-signed and must not be used — the gateway proxies all three
# stores over TLS with a single token:
#
#   SPARQL      POST {OPENPULSE_ENDPOINT}/sparql/query
#   Cypher      POST {OPENPULSE_ENDPOINT}/api/databases/cypher/query
#   OpenSearch  POST {OPENPULSE_ENDPOINT}/api/databases/opensearch/query  (SQL or DSL)
#   CHAOSS      GET  {OPENPULSE_ENDPOINT}/api/v1/metrics/chaoss/…
#   Hub ops     collections / quests / crawler-jobs APIs
#
# Auth format everywhere: <user>/<password> over HTTP Basic. For hub reader
# and admin sessions the username part is ignored — only the token matters.

OPENPULSE_ENDPOINT=https://openpulse.epfl.ch
# Reader token — enough for ALL read/monitoring calls across every skill.
OPENPULSE_AUTH=reader/replace-me

# Admin session — REQUIRED only for mutating operations: running/creating/
# stopping a quest (op-extractor) and pausing/resuming/cancelling/deleting
# a crawl (op-crawler). Without it those calls return
# `403 "Reader sessions can't trigger mutating endpoints…"`.
#OPENPULSE_ADMIN_AUTH=admin/replace-me

# ── Optional overrides ────────────────────────────────────────────────────
# Every skill derives its URL and auth from OPENPULSE_ENDPOINT/OPENPULSE_AUTH.
# Set these only to point one store somewhere else (e.g. a local dev stack).
#SPARQL_ENDPOINT=https://openpulse.epfl.ch/sparql
#SPARQL_AUTH=reader/replace-me
#CHAOSS_ENDPOINT=https://openpulse.epfl.ch
#CHAOSS_AUTH=reader/replace-me
